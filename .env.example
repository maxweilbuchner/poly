# Credentials can also be stored in ~/.poly/config.toml instead of a .env file.
# See config.toml.example for the format. Environment variables always take priority.

# Wallet private key (EOA that signs EIP-712 orders)
POLY_PRIVATE_KEY=0x...

# Optional: proxy/funder address if using a Gnosis Safe or proxy wallet
# If set, this is used as maker address and signatureType=1 is used
POLY_FUNDER_ADDRESS=0x...

# CLOB API credentials (from https://polymarket.com/profile)
POLY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POLY_API_SECRET=...
POLY_API_PASSPHRASE=...

# Polygon mainnet RPC — required for balance/allowance checks
# Get a free key at https://dashboard.alchemy.com or https://infura.io
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
