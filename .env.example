# Polymarket CLI — Environment Variables
# Copy this file to .env and fill in your values.
# Only POLY_PRIVATE_KEY is required for trading; search/book commands work without credentials.

# ── Wallet / Signing ─────────────────────────────────────────────────────────

# EOA private key (signs EIP-712 orders). Required for trading.
POLY_PRIVATE_KEY=

# Proxy/funder wallet address (optional — only if using a delegated/proxy wallet).
# POLY_FUNDER_ADDRESS=

# ── CLOB API Credentials ─────────────────────────────────────────────────────
# Obtain these via `poly derive-keys` or the Polymarket CLOB API.

POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── RPC ───────────────────────────────────────────────────────────────────────

# Polygon RPC URL (Alchemy, Infura, etc.) — needed for balance checks and redemptions.
POLYGON_RPC_URL=

# ── Logging ───────────────────────────────────────────────────────────────────

# Set RUST_LOG to control log verbosity (e.g. "poly=debug", "poly=trace").
# RUST_LOG=poly=info
