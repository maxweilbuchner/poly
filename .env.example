# Required for trading — export from MetaMask or another wallet
POLY_PRIVATE_KEY=0x...

# CLOB API credentials — run `poly derive-keys` to generate these
POLY_API_KEY=...
POLY_API_SECRET=...
POLY_API_PASSPHRASE=...

# Optional — Polygon RPC endpoint for on-chain balance checks
# Get a free key from https://alchemy.com or https://infura.io
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional — only if trading through a proxy wallet or Gnosis Safe
# POLY_FUNDER_ADDRESS=0x...
